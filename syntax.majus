// comments start with //

// make a variable mutable with ~
// var @parameters name: type = value;
var immutableVariable: i32 = 14;
var~ (x, y): (i32, i32) = (15, 43);

// declare an array
var~ nums: [i32, 5] = [1, 2, 3, 4, 5]:
nums[2] = 7;

// declare a function
fun add(x: i32, y: i32): i32 => {
    x + y;
}