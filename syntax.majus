// comments start with //

// make a variable mutable with ~
// var @parameters name: type = value;
var immutableVariable: word = 14;
var~ (x, y): (word, word) = (15, 43);

// declare an array
var~ nums: [uqword, 5] = [1, 2, 3, 4, 5]:
nums[2] = 7;

// declare a function
fun add(x: word, y: word): word => {
    x + y;
}